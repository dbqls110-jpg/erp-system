generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 사용자 ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("pending") // "admin" | "user" | "pending"
  isAgent       Boolean   @default(false)     // true = Agent bot
  agentType     String?                        // "hermes" | "marketer" | null
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  attendances   Attendance[]
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
  expenses      Expense[]
  businessCards   BusinessCard[]
  calendarEvents    CalendarEvent[]
  conversationsAsA  Conversation[]  @relation("ConvA")
  conversationsAsB  Conversation[]  @relation("ConvB")
  sentMessages      Message[]       @relation("MessageSender")

  @@map("users")
}

// ─── NextAuth ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── 근태 ─────────────────────────────────────────────────
model Attendance {
  id        String    @id @default(cuid())
  userId    String
  date      String    // "YYYY-MM-DD"
  clockIn   DateTime?
  clockOut  DateTime?
  workHours Float?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("attendances")
}

// ─── 휴가 ─────────────────────────────────────────────────
model LeaveBalance {
  id          String   @id @default(cuid())
  userId      String
  year        Int
  totalDays   Float    @default(15)
  usedDays    Float    @default(0)
  pendingDays Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id           String   @id @default(cuid())
  userId       String
  type         String   // "annual" | "half_am" | "half_pm" | "hourly"
  startDate    String   // "YYYY-MM-DD"
  endDate      String   // "YYYY-MM-DD"
  startTime    String?
  endTime      String?
  days         Float
  reason       String?
  status       String   @default("pending") // "pending" | "approved" | "rejected"
  adminNote    String?
  notionPageId String?  // Notion page ID (승인 시 생성)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("leave_requests")
}

// ─── 프로젝트 ─────────────────────────────────────────────
model Project {
  id           String   @id @default(cuid())
  name         String
  client       String?
  announceDate String?
  deadline     String?
  status       String   @default("active") // "active" | "completed" | "on_hold"
  progress     Float    @default(0)
  assignee     String?
  memo         String?
  revenue      Float?   // 매출
  cost         Float?   // 매입
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  checklistItems ChecklistItem[]
  files          ProjectFile[]

  @@map("projects")
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String
  driveFileId String
  name        String
  mimeType    String
  driveUrl    String
  size        Int?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_files")
}

model ChecklistItem {
  id        String   @id @default(cuid())
  projectId String
  content   String
  isDone    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ─── 고정비 ───────────────────────────────────────────────
model FixedExpense {
  id         String   @id @default(cuid())
  name       String
  amount     Float
  dayOfMonth Int      // 매달 몇일
  category   String   // "rent" | "salary" | "telecom" | "supplies" | "food" | "other"
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("fixed_expenses")
}

// ─── 재무 ─────────────────────────────────────────────────
model Budget {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
  @@map("budgets")
}

model Expense {
  id             String   @id @default(cuid())
  userId         String
  date           String   // "YYYY-MM-DD"
  title          String
  category       String   // "rent" | "salary" | "telecom" | "supplies" | "food" | "other"
  amount         Float
  memo           String?
  fixedExpenseId String?  // 고정비에서 생성된 경우
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([date])
  @@map("expenses")
}

// ─── 메신저 ───────────────────────────────────────────────
model Conversation {
  id           String    @id @default(cuid())
  participantA String
  participantB String
  lastMessageAt DateTime @default(now())
  createdAt    DateTime  @default(now())

  userA    User      @relation("ConvA", fields: [participantA], references: [id], onDelete: Cascade)
  userB    User      @relation("ConvB", fields: [participantB], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([participantA, participantB])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt, senderId])
  @@map("messages")
}

// ─── Agent 감사 로그 ──────────────────────────────────────
model AgentAuditLog {
  id        String   @id @default(cuid())
  method    String   // GET | POST | PATCH
  endpoint  String   // /api/agent/projects
  action    String   // create_project | update_project | send_message ...
  dryRun    Boolean  @default(false)
  payload   Json?    // 요청 내용
  result    Json?    // 결과 (dryRun이면 예상 결과)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("agent_audit_logs")
}

// ─── 캘린더 ───────────────────────────────────────────────
model CalendarEvent {
  id           String   @id @default(cuid())
  title        String
  date         String   // "YYYY-MM-DD"
  endDate      String?  // "YYYY-MM-DD"
  color        String   @default("gray") // "gray" | "blue" | "green" | "red" | "yellow" | "purple"
  createdBy    String
  notionPageId String?  // Notion page ID (양방향 동기화용)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

// ─── ID 데이터베이스 ──────────────────────────────────────
model Credential {
  id        String   @id @default(cuid())
  name      String   // 서비스명
  company   String?  // 회사
  category  String?  // 구분 (나라장터, Google, Naver, etc.)
  username  String?  // 아이디
  password  String?  // 비밀번호
  memo      String?  // 비고
  url       String?  // 링크
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("credentials")
}

// ─── 구글 시트 디렉토리 ───────────────────────────────────
model SheetLink {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String?
  category    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sheet_links")
}

// ─── Agent 메시지 처리 기록 ──────────────────────────────
model AgentMessageProcessing {
  id              String    @id @default(cuid())
  messageId       String
  agentType       String    // "hermes" | "marketer"
  status          String    @default("processed") // "processing" | "processed" | "error"
  processedAt     DateTime?
  resultMessageId String?   // 답장 messageId
  error           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([messageId, agentType])
  @@index([agentType, createdAt])
  @@map("agent_message_processing")
}

// ─── 명함 ─────────────────────────────────────────────────
model BusinessCard {
  id         String   @id @default(cuid())
  userId     String
  name       String
  company    String?
  jobTitle   String?
  phone      String?
  email      String?
  address    String?
  imagePath  String?
  rawOcrText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_cards")
}
