# ──────────────────────────────────────────────────────────────
#  회사 PC (Hermes 브릿지) 환경변수
#  이 파일을 복사해 hermes.env 로 저장 후 값을 채워주세요.
# ──────────────────────────────────────────────────────────────

# ERP 서버 주소
ERP_BASE_URL=https://erp-system-lojo.onrender.com

# Hermes 전용 브릿지 키 (Render 환경변수 HERMES_BRIDGE_API_KEY와 동일)
ERP_AGENT_API_KEY=your-hermes-bridge-api-key-here

# Anthropic API 키 (Claude 호출용)
ANTHROPIC_API_KEY=sk-ant-...

# 고정: hermes (변경 금지)
AGENT_TYPE=hermes

# 운영 시간 KST (기본: 오전 8시 ~ 새벽 1시)
AGENT_OPEN_HOUR=8
AGENT_CLOSE_HOUR=1
