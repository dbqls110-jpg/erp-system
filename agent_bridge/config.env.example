# ERP Agent Bridge 환경변수 설정 파일
# 이 파일을 복사해 .env 로 이름 변경 후 값을 채워주세요.

# ERP 서버 주소
ERP_BASE_URL=https://erp-system-lojo.onrender.com

# ERP Agent API 키 (Render 환경변수 ERP_AGENT_API_KEY와 동일)
ERP_AGENT_API_KEY=your-erp-agent-api-key-here

# Anthropic API 키 (Claude 호출용)
ANTHROPIC_API_KEY=sk-ant-...

# 에이전트 타입: hermes 또는 marketer
AGENT_TYPE=hermes

# 운영 시간 (KST 24시 기준, 기본: 08~01)
AGENT_OPEN_HOUR=8
AGENT_CLOSE_HOUR=1

# 폴링 인터벌 (초, 기본: 3)
AGENT_POLL_INTERVAL=3
