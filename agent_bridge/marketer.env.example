# ──────────────────────────────────────────────────────────────
#  노트북 (Marketer 브릿지) 환경변수
#  이 파일을 복사해 marketer.env 로 저장 후 값을 채워주세요.
#
#  Anthropic API 키 불필요 — 이 노트북의 Hermes 구독·로그인을 그대로 사용합니다.
#  실행 전: hermes status 로 로그인 상태를 확인하고,
#           마케터 프로필이 설정돼 있다면 hermes profile use <프로필명> 으로 전환하세요.
# ──────────────────────────────────────────────────────────────

# ERP 서버 주소
ERP_BASE_URL=https://erp-system-lojo.onrender.com

# Marketer 전용 브릿지 키 (Render 환경변수 MARKETER_BRIDGE_API_KEY와 동일)
ERP_AGENT_API_KEY=your-marketer-bridge-api-key-here

# 고정: marketer (변경 금지)
AGENT_TYPE=marketer

# 운영 시간 KST (기본: 오전 8시 ~ 새벽 1시)
AGENT_OPEN_HOUR=8
AGENT_CLOSE_HOUR=1
