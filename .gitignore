# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# agent_bridge local runtime files (contain secrets / local state)
agent_bridge/hermes.env
agent_bridge/marketer.env
agent_bridge/*.log
agent_bridge/*.lock
agent_bridge/__pycache__/
agent_bridge/**/__pycache__/
agent_bridge/.pytest_cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# SQLite
*.db
*.db-journal
